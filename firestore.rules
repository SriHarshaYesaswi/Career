rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check user auth
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Match users collection
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      // Match nested collections
      match /activities/{id} {
        allow read, write: if isOwner(uid);
      }
      match /goals/{id} {
        allow read, write: if isOwner(uid);
      }
      match /skills/{id} {
        allow read, write: if isOwner(uid);
      }
      match /certificates/{id} {
        allow read, write: if isOwner(uid);
      }
      match /roadmaps/{id} {
        allow read, write: if isOwner(uid);
      }
      match /journal/{id} {
        allow read, write: if isOwner(uid);
      }
      match /applications/{id} {
        allow read, write: if isOwner(uid);
      }
      match /courses/{id} {
        allow read, write: if isOwner(uid);
      }
      match /past_semesters/{id} {
        allow read, write: if isOwner(uid);
      }
      match /exams/{id} {
        allow read, write: if isOwner(uid);
      }
      match /projects/{id} {
        allow read, write: if isOwner(uid);
      }
    }
  }
}
