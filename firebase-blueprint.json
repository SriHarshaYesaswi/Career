{
  "$schema": "https://firebase.google.com/schemas/firestore/blueprint/v1",
  "collections": {
    "users": {
      "path": "users/{uid}",
      "schema": {
        "uid": "string",
        "name": "string",
        "email": "string",
        "photoUrl": "string?",
        "profession": "string",
        "currentEducation": "string",
        "collegeName": "string?",
        "degree": "string?",
        "yearOfStudy": "string?",
        "targetRole": "string?",
        "skills": "array<string>",
        "careerInterests": "array<string>",
        "resumeUrl": "string?",
        "resumeFileName": "string?",
        "githubUrl": "string?",
        "linkedinUrl": "string?",
        "streakCount": "number",
        "lastActiveDate": "string?",
        "productivityScore": "number",
        "authProvider": "string?",
        "createdAt": "string?",
        "lastLogin": "string?",
        "careerScore": "number?",
        "level": "number?",
        "xp": "number?",
        "onboarded": "boolean?"
      },
      "allow": {
        "read": "auth != null && auth.uid == uid",
        "write": "auth != null && auth.uid == uid"
      }
    },
    "activities": {
      "path": "users/{uid}/activities/{id}",
      "schema": {
        "id": "string",
        "userId": "string",
        "title": "string",
        "description": "string",
        "category": "string",
        "date": "string",
        "startTime": "string",
        "endTime": "string",
        "priority": "string",
        "status": "string",
        "hoursSpent": "number"
      },
      "allow": {
        "read": "auth != null && auth.uid == uid",
        "write": "auth != null && auth.uid == uid"
      }
    },
    "goals": {
      "path": "users/{uid}/goals/{id}",
      "schema": {
        "id": "string",
        "userId": "string",
        "title": "string",
        "description": "string?",
        "isLongTerm": "boolean",
        "deadline": "string",
        "category": "string",
        "progressPercentage": "number",
        "isCompleted": "boolean"
      },
      "allow": {
        "read": "auth != null && auth.uid == uid",
        "write": "auth != null && auth.uid == uid"
      }
    },
    "skills": {
      "path": "users/{uid}/skills/{id}",
      "schema": {
        "id": "string",
        "userId": "string",
        "name": "string",
        "currentLevel": "number",
        "targetLevel": "number",
        "learningHours": "number",
        "progressPercentage": "number",
        "category": "string?"
      },
      "allow": {
        "read": "auth != null && auth.uid == uid",
        "write": "auth != null && auth.uid == uid"
      }
    }
  }
}
