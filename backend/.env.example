# Backend Environment Variables
# Copy this file to .env and fill in values

# MongoDB Connection String
MONGODB_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/dbname?appName=...

# JWT Secret for session signing (keep this secret!)
JWT_SECRET=your_super_secret_jwt_key_here

# Gemini AI API Key (for AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# API base URL (used for OAuth callback URLs)
# Local dev: http://localhost:3000
# Production: https://career-5cyc.onrender.com
API_BASE_URL=http://localhost:3000

# Frontend URL (for OAuth redirect after login)
# Local dev: http://localhost:5173
# Production: https://career-high.vercel.app
FRONTEND_URL=http://localhost:5173
